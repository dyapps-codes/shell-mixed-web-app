{
  "name": "@dypai-ai/client-sdk",
  "version": "1.12.0",
  "description": "Official JavaScript/TypeScript SDK for DYPAI — backend-as-a-service with visual workflows, AI agents, and MCP.",
  "type": "module",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.esm.js",
      "require": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "dev": "NODE_ENV=development rollup -c -w",
    "dev:watch": "NODE_ENV=development rollup -c -w",
    "dev:test": "vite",
    "type-check": "tsc --noEmit",
    "test:types": "tsc --noEmit -p tsconfig.type-tests.json",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "clean": "rimraf dist docs",
    "prepublishOnly": "npm run clean && npm run build && npm run type-check && npm run docs",
    "publish:public": "npm publish --access public"
  },
  "keywords": [
    "dypai",
    "sdk",
    "backend-as-a-service",
    "baas",
    "api",
    "auth",
    "database",
    "workflows",
    "react",
    "typescript"
  ],
  "author": "DYPAI Solutions <dev@dypai.ai>",
  "homepage": "https://dypai.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/DYPAI-SOLUTIONS/client-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/DYPAI-SOLUTIONS/client-sdk/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "dotenv": "^17.2.2",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.0.0",
    "vite": "^7.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "better-auth": "^1.6.0"
  }
}
